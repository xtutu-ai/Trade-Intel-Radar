APP_ENV=prod
TIMEZONE=Asia/Shanghai

# X API - optional, without it the X collector is skipped
X_BEARER_TOKEN=

# LLM - OpenAI compatible. OpenRouter example:
LLM_PROVIDER=openrouter
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=
LLM_MODEL=openai/gpt-4.1-mini
LLM_FALLBACK_MODEL=deepseek/deepseek-chat
LLM_TIMEOUT_SECONDS=120
LLM_MAX_INPUT_ITEMS=80
LLM_MAX_TOKENS=3500

# Mail SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=
MAIL_TO=

# Runtime limits for small 2C/2G instance
MAX_TOTAL_ITEMS=250
HTTP_TIMEOUT_SECONDS=20
